generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id String @id @default(cuid())

  email String @unique

  createdAt DateTime @default(now())
}


model ResumeAnalysis {

  id String @id @default(cuid())

  filename String

  extractedText String

  analysis Json

  createdAt DateTime @default(now())

}